# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file and set values for your deployment platform.
# On Railway and Fly.io, set these as secrets/variables in the platform dashboard.

# =============================================================================
# DATABASE & CACHE (Required)
# =============================================================================
BOARDS_DATABASE_URL=postgresql://user:password@host:5432/boards
BOARDS_REDIS_URL=redis://host:6379/0

# =============================================================================
# API CONFIGURATION (Required)
# =============================================================================
BOARDS_API_PORT=8800
BOARDS_JWT_SECRET=generate-a-random-32-char-secret
BOARDS_LOG_FORMAT=json
BOARDS_LOG_LEVEL=info

# CORS — JSON array of allowed frontend origins
BOARDS_CORS_ORIGINS=["https://your-frontend-domain.com"]

# Internal API URL (set on worker service only)
# Railway: http://${{api.RAILWAY_PRIVATE_DOMAIN}}:8800
# Fly.io:  http://boards-api.internal:8800
BOARDS_INTERNAL_API_URL=http://api:8800

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================
# Options: none, clerk, supabase, jwt, auth0
BOARDS_AUTH_PROVIDER=none

# --- Clerk ---
# BOARDS_AUTH_PROVIDER=clerk
# CLERK_SECRET_KEY=sk_live_...

# --- Supabase ---
# BOARDS_AUTH_PROVIDER=supabase
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=...

# --- JWT ---
# BOARDS_AUTH_PROVIDER=jwt
# BOARDS_JWT_SECRET=your-secret

# --- Auth0 ---
# BOARDS_AUTH_PROVIDER=auth0
# AUTH0_DOMAIN=...
# AUTH0_CLIENT_ID=...
# AUTH0_CLIENT_SECRET=...

# =============================================================================
# FRONTEND (Required for web service)
# =============================================================================
NEXT_PUBLIC_API_URL=https://your-api-domain.com
NEXT_PUBLIC_GRAPHQL_URL=https://your-api-domain.com/graphql
NEXT_PUBLIC_AUTH_PROVIDER=none

# --- Clerk (frontend) ---
# NEXT_PUBLIC_AUTH_PROVIDER=clerk
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...

# --- Supabase (frontend) ---
# NEXT_PUBLIC_AUTH_PROVIDER=supabase
# NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=...

# =============================================================================
# PROVIDER API KEYS (set at least one)
# =============================================================================
REPLICATE_API_TOKEN=
FAL_KEY=
KIE_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# =============================================================================
# OBJECT STORAGE (S3-Compatible)
# =============================================================================
# Used by Railway Buckets, Fly.io Tigris, AWS S3, MinIO, R2, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_ENDPOINT_URL_S3=             # Set for non-AWS S3-compatible services
# AWS_REGION=auto                  # Set if required by provider

# =============================================================================
# CONFIGURATION PATHS
# =============================================================================
BOARDS_STORAGE_CONFIG_PATH=/app/config/storage_config.yaml
BOARDS_GENERATORS_CONFIG_PATH=/app/config/generators.yaml
