# Supabase Configuration
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secrets (never exposed to browser)
# Service Role Key: Settings -> API -> Service Role Key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT Secret: Settings -> API -> JWT Settings
SUPABASE_JWT_SECRET=your-jwt-secret

# Supabase project ID (for type generation via `pnpm update-types`)
SUPABASE_PROJECT_ID=your-project-id

# Boards API URL (backend GraphQL endpoint)
NEXT_PUBLIC_BOARDS_API_URL=http://localhost:8088
